# Veridex Multisig Wallet - Environment Variables
# Copy this file to .env.local and fill in the values

# Database (Prisma SQLite)
DATABASE_URL="file:./data/multisig.db"

# Relayer URL for gasless transactions
NEXT_PUBLIC_RELAYER_URL=https://relayer.veridex.network/api/v1

# Relayer API key (optional)
NEXT_PUBLIC_RELAYER_API_KEY=

# RPC URLs (defaults to public endpoints)
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Gas sponsorship keys (optional - enables gasless vault creation)
NEXT_PUBLIC_INTEGRATOR_SPONSOR_KEY=
NEXT_PUBLIC_VERIDEX_SPONSOR_KEY=
